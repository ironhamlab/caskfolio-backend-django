# Django secret key (아래 명령어로 생성: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())')
SECRET_KEY=your-secret-key-here

# Debug mode (개발: True, 배포: False)
DEBUG=True

# OpenAI API key (https://platform.openai.com/api-keys 에서 발급)
OPENAI_API_KEY=sk-your-api-key-here